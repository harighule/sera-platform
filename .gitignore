# ============================================================
# SERA Platform — Root .gitignore
# Merged from: user requirements + backend/.gitignore + frontend/.gitignore
# ============================================================

# ── Secrets & Environment ───────────────────────────────────
.env
*.env
backend/.env
.env.local
.env.*.local
credentials/
backend/credentials/
trace_output.txt

# ── Python bytecode & caches ────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
*.egg-info/
.mypy_cache/

# ── Python virtual environments ─────────────────────────────
.venv/
venv/
env/

# ── Python build artifacts ──────────────────────────────────
dist/
build/

# ── Databases ───────────────────────────────────────────────
*.db
*.sqlite3
backend/sera_db.sqlite3

# ── Machine-learning model weights (often too large for git) ─
*.pt
*.pth
*.ckpt
*.onnx
*.bin

# ── Logs ────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── JavaScript / Node ───────────────────────────────────────
node_modules/
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
*.local

# ── Editor & OS ─────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
